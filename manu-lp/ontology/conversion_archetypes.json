      "hero_pattern": {
        "headline_focus": "transformation",
        "cta_text": ["Enroll Now", "Join the Program", "Start Your Transformation"],
        "micro_copy": ["Limited spots", "Lifetime access", "Money-back guarantee"]
      },
      "trust_signals": {
        "priority": ["student_results", "video_testimonials", "curriculum_preview"],
        "testimonial_focus": "before_after"
      },
      "friction_reducers": ["payment_plans", "sample_content", "money_back_guarantee"],
      "urgency_type": "deadline_cohort",
      "conversion_benchmark": {
        "average": 1.5,
        "good": 3.0,
        "elite": 6.0
      }
    },
    "webinar_registration": {
      "id": "ARCH-006",
      "name": "Webinar / Event Registration",
      "characteristics": {
        "awareness_level": "problem_aware",
        "price_sensitivity": "low",
        "decision_timeline": "instant",
        "risk_perception": "low"
