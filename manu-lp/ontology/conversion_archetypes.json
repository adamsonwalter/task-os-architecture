      },
      "trust_signals": {
        "priority": ["host_credentials", "registrant_count", "past_attendee_quotes"],
        "testimonial_focus": "webinar_value"
      },
      "friction_reducers": ["calendar_add", "reminder_option", "replay_promise"],
      "urgency_type": "deadline_event",
      "conversion_benchmark": {
        "average": 25.0,
        "good": 40.0,
        "elite": 55.0
      }
    },
    "agency_service": {
      "id": "ARCH-007",
      "name": "Agency / Service Business",
      "characteristics": {
        "awareness_level": "solution_aware",
        "price_sensitivity": "medium",
        "decision_timeline": "long",
        "risk_perception": "high"
      },
      "hero_pattern": {
        "headline_focus": "result_mechanism",
        "cta_text": ["Get a Quote", "Book Discovery Call", "Start a Project"],
        "micro_copy": ["Custom solutions", "No obligation", "Results guaranteed"]
      },
      "trust_signals": {
        "priority": ["portfolio", "case_studies", "industry_expertise"],
        "testimonial_focus": "client_outcomes"
      },
      "friction_reducers": ["free_audit", "portfolio_preview", "clear_process"],
      "urgency_type": "capacity",
      "conversion_benchmark": {
        "average": 3.0,
        "good": 6.0,
        "elite": 10.0
      }
    }
  },
  "archetype_selection_logic": {
    "by_offer_type": {
      "software_trial": "saas_free_trial",
      "software_demo": "saas_demo_request",
      "pdf_guide": "lead_magnet",
      "email_course": "lead_magnet",
      "checklist": "lead_magnet",
      "physical_product": "ecommerce_product",
      "digital_product": "ecommerce_product",
      "online_course": "coaching_program",
      "coaching": "coaching_program",
      "mastermind": "coaching_program",
      "live_webinar": "webinar_registration",
      "virtual_event": "webinar_registration",
      "consulting": "agency_service",
      "done_for_you": "agency_service"
