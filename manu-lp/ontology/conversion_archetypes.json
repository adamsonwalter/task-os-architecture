    "modifiers": {
      "high_ticket": ["add_demo_step", "emphasize_trust", "longer_page"],
      "low_ticket": ["remove_friction", "shorten_page", "impulse_triggers"],
      "b2b": ["add_enterprise_signals", "emphasize_roi", "include_compliance"],
      "b2c": ["emotional_triggers", "social_proof_volume", "simple_language"]
    }
  }
